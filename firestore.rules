rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidChat(data) {
      return data.keys().hasAll(['userId', 'title', 'type', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 100 &&
             data.type in ['fake', 'owner'] &&
             data.createdAt == request.time;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['chatId', 'sender', 'content', 'type', 'timestamp']) &&
             data.keys().size() == 5 &&
             data.chatId is string &&
             data.sender in ['user', 'ai'] &&
             data.content is string && data.content.size() <= 20000 &&
             data.type in ['text', 'image', 'audio', 'file', 'code'] &&
             data.timestamp == request.time;
    }

    // --- Matches ---
    match /chats/{chatId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidChat(incoming());
      
      allow update: if isSignedIn() && 
                      isOwner(existing().userId) && 
                      incoming().userId == existing().userId &&
                      incoming().type == existing().type &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['title']);
      
      allow delete: if isSignedIn() && isOwner(existing().userId);

      match /messages/{messageId} {
        // Only allow reading messages if user owns the parent chat
        allow read: if isSignedIn() && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
        
        // Only allow creating if user owns chat and data is valid
        allow create: if isSignedIn() && 
                        get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid &&
                        isValidMessage(incoming());
      }
    }
  }
}
